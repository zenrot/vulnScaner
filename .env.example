# SAST Agent Server — environment variables
# Copy to .env and adjust for your setup.

# ── Server ──────────────────────────────────────────────────────────────────
SAST_SERVER_ADDR=:8080
SAST_API_PORT=10000       # host port for API; container still listens on 8080
SAST_UI_PORT=10001        # host port for Web UI; container still listens on 80
SAST_WORKERS=4
SAST_INCLUDE_TESTS=false

# ── AI provider ─────────────────────────────────────────────────────────────
# Allowed: ollama, ollama-agentic, openai, openai-agentic, gigachat, gigachat-agentic
SAST_AI_PROVIDER=ollama-agentic
SAST_AI_BUDGET=10          # max findings to triage per scan (0 = unlimited)
SAST_AI_PARALLEL=2         # concurrent triage calls (keep low for local Ollama)
SAST_SNIPPET_RADIUS=14     # context lines around each finding

# ── Ollama (local) ──────────────────────────────────────────────────────────
SAST_OLLAMA_URL=http://ollama:11434
# ollama-init pulls this model automatically before the API starts.
SAST_OLLAMA_MODEL=qwen2.5:3b-instruct
SAST_OLLAMA_NUM_CTX=4096

# ── OpenAI-compatible (cloud) ────────────────────────────────────────────────
# SAST_OPENAI_URL=https://api.openai.com/v1
# SAST_OPENAI_MODEL=gpt-4o-mini
# SAST_OPENAI_KEY=sk-...

# ── GigaChat ────────────────────────────────────────────────────────────────
# SAST_GIGACHAT_SCOPE=GIGACHAT_API_PERS
# SAST_GIGACHAT_KEY=<base64-authorization-key>

# ── Policy ──────────────────────────────────────────────────────────────────
SAST_FAIL_ON_SEVERITY=HIGH
SAST_FAIL_ON_VERDICT=true_positive

# ── History ─────────────────────────────────────────────────────────────────
# SAST_HISTORY_DIR=/app/history

# ── Feedback (optional override file) ───────────────────────────────────────
# SAST_FEEDBACK_IN=/app/feedback.json
